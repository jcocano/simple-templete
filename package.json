{
  "name": "simple-template-desktop",
  "productName": "Simple Template",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE ELECTRON_START_URL=http://127.0.0.1:5173 electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:web": "vite build",
    "test:export": "node scripts/smoke-test-export.mjs"
  },
  "dependencies": {
    "basic-ftp": "^5.3.0",
    "better-sqlite3": "^12.9.0",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.0",
    "esbuild": "^0.28.0",
    "vite": "^8.0.9",
    "wait-on": "^9.0.3"
  }
}
