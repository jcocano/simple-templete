{
  "name": "simple-template-desktop",
  "productName": "Simple Template",
  "version": "0.1.0",
  "description": "Open-source, local-first desktop app to design email templates visually — a no-code Beefree alternative for macOS, Windows and Linux.",
  "private": true,
  "main": "electron/main.js",
  "author": "Jesus Cocaño <jesus.cocano@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/jcocano/simple-templete",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcocano/simple-templete.git"
  },
  "bugs": {
    "url": "https://github.com/jcocano/simple-templete/issues"
  },
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && node scripts/run-dev-electron.mjs",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:web": "vite build",
    "pack": "npm run build:web && electron-builder --dir",
    "dist": "npm run build:web && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "test:export": "node scripts/smoke-test-export.mjs"
  },
  "build": {
    "appId": "com.simpletemplate.app",
    "productName": "Simple Template",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json",
      "!**/*.{py,md,map,tsbuildinfo}"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Office",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "basic-ftp": "^5.3.0",
    "better-sqlite3": "^12.9.0",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "vite": "^8.0.9",
    "wait-on": "^9.0.3"
  }
}
